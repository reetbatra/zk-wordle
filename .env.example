# =====================================================================
# zk-wordle on Midnight — environment configuration
#
# Copy to `.env` and fill in WALLET_SEED. The other values are sane
# defaults for Midnight's `preprod` testnet plus a local proof server.
# Never commit `.env`.
# =====================================================================

# Which Midnight network to target.
#   preprod     - shared testnet, what Lace / 1AM default to (recommended)
#   preview     - alternate public testnet
#   undeployed  - fully local stack (requires running node/indexer locally)
NETWORK_ID=preprod

# Preprod testnet endpoints. The midnight-js 4.x indexer provider speaks
# the v3 GraphQL API on preprod.
MN_NODE=https://rpc.preprod.midnight.network
MN_INDEXER=https://indexer.preprod.midnight.network/api/v3/graphql
MN_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v3/graphql/ws

# Proof server. Default is the local Docker container on :6300.
# IMPORTANT: keep this LOCAL — the proof server sees the witnesses
# (secret word + salt). A remote proof server defeats zk-wordle's
# privacy story. Start it (Docker/Colima must be running) with either:
#   docker compose -f proof-server.yml up -d   # if the compose plugin is installed
#   npm run proof-server                       # plain `docker run`, no plugin needed
MN_PROOF_SERVER=http://127.0.0.1:6300

# Wallet secret for the wallet that pays transaction fees. Accepts EITHER:
#   - a 64-char hex seed, OR
#   - a BIP39 recovery phrase (12-24 words) — this is what 1AM / Lace export.
# Use your 1AM wallet's recovery phrase so the CLI spends its existing funds.
# On first run the CLI prints the derived unshielded (tNight) address —
# confirm it matches the address 1AM shows you. (For a recovery phrase, never
# paste one that also guards mainnet funds; this file is gitignored either way.)
#
# Funding model on preprod:
#   - You hold tNight (unshielded NIGHT). Get it from the faucet:
#       https://faucet.preprod.midnight.network/
#   - Fees are paid in DUST, which is generated over time from NIGHT
#     UTXOs once they're registered for dust generation. The CLI does
#     this registration automatically on startup.
WALLET_SEED=

# Optional. How to derive the HD seed from a recovery phrase:
#   entropy (default) - the BIP39 entropy the words encode (1AM/Lace style).
#   bip39             - the 64-byte PBKDF2 seed. Only set this if the address
#                       printed on startup does NOT match your wallet.
# SEED_DERIVATION=entropy

# Logging verbosity for the CLI: trace | debug | info | warn | error
DEBUG_LEVEL=info
